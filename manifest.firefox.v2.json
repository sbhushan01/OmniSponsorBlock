{
  "manifest_version": 2,
  "name": "OmniSponsorBlock",
  "version": "1.0.23",
  "default_locale": "en",
  "description": "Skip SponsorBlock segments on YouTube and Spotify podcasts.",
  "icons": {
    "64": "icons/IconSponsorBlocker64px.png",
    "128": "icons/IconSponsorBlocker128px.png"
  },
  "permissions": [
    "storage",
    "webRequest",
    "alarms",
    "tabs",
    "https://*.youtube.com/*",
    "https://www.youtubekids.com/*",
    "https://sponsor.ajay.app/*",
    "https://googleusercontent.com/*",
    "https://open.spotify.com/*"
  ],
  "background": {
    "scripts": [
      "js/background.js"
    ],
    "persistent": false
  },
  "browser_action": {
    "default_title": "OmniSponsorBlock",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://www.youtubekids.com/*"
      ],
      "js": [
        "js/content-youtube.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://open.spotify.com/*",
        "https://googleusercontent.com/*"
      ],
      "js": [
        "js/content-spotify.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "js/spotify-inject.js",
    "styles/ui.css"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "omnisponsorblock@sbhushan01.github.io",
      "strict_min_version": "109.0",
      "update_url": "https://sbhushan01.github.io/OmniSponsorBlock/updates.json"
    }
  },
  "data_collection_permissions": {
    "required": [],
    "optional": []
  }
}
